# Public app config
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_BEQUEST_PACKAGE_ID=0x
NEXT_PUBLIC_BEQUEST_ESTATE_MODULE=estate
# Optional override. By default, Lane B targets the deployed distribution call:
# 0xPACKAGE::estate::distribute_coin with type argument 0x2::sui::SUI.
# Fill this only if Lane A later adds a dedicated heir claim entrypoint.
NEXT_PUBLIC_BEQUEST_CLAIM_TARGET=
# Optional final V2 proof gate. Leave empty until a real Enoki-sponsored claim
# transaction lands; public copy must not claim gasless proof without this.
NEXT_PUBLIC_BEQUEST_SPONSORED_CLAIM_DIGEST=
# Last-wishes letter pointer for the judge estate (the package stores no wishes
# metadata on-chain yet, so these are pinned). Capture both when encrypting +
# uploading the letter: blob id from the Walrus publisher, inner id = hex of
# [estate id bytes][nonce] passed to Seal at encrypt time. WishesLetter stays
# hidden until both are set. Optional aggregator override defaults to testnet.
NEXT_PUBLIC_BEQUEST_WISHES_BLOB_ID=
NEXT_PUBLIC_BEQUEST_WISHES_INNER_ID=
NEXT_PUBLIC_WALRUS_AGGREGATOR=
NEXT_PUBLIC_ENOKI_PUBLIC_API_KEY=
NEXT_PUBLIC_ENOKI_CONNECT_APP_SLUG=

# Server-only Enoki config. Never expose this in client components.
ENOKI_PRIVATE_API_KEY=

# Optional sponsor safety rails. Comma-separated.
# Default Move target format: 0xPACKAGE::estate::distribute_coin
ENOKI_ALLOWED_ADDRESSES=
ENOKI_ALLOWED_MOVE_TARGETS=
